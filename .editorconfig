# .NET extensions (R9)
dotnet_diagnostic.LOGGEN030.severity = none # Logging method doesn't log anything

# experimental APIs
dotnet_diagnostic.R9EXP0020.severity = none
dotnet_diagnostic.R9EXP0014.severity = none
dotnet_diagnostic.EXTEXP0015.severity = none

# C# tests
[**/*{Test,Tests}/**{Test,Tests,TestBase,TestsBase}.cs]
dotnet_diagnostic.CA2007.severity = none # disable ConfigureAwait enforcement

# c# test libraries
[**/*{Test,Tests}/**.cs]
dotnet_diagnostic.CA5394.severity = none # allow use of regular Random

# Durable task orchestrators
[**/*{Orchestrator,OrchestratorBase}.cs]
dotnet_diagnostic.CA2007.severity = none # disable ConfigureAwait enforcement

# C# converters
[*{Converter,Converters}.cs]
dotnet_diagnostic.IDE0072.severity = error # enforce add missing cases to switch expression

# XAML
[*.xaml]
indent_size = 4
charset = utf-8-bom
insert_final_newline = true
trim_trailing_whitespace = true

