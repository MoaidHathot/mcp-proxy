{
  // Proxy-level settings (all optional)
  "proxy": {
    "serverInfo": {
      "name": "My MCP Proxy",
      "version": "1.0.0",
      "instructions": "This proxy aggregates multiple MCP servers."
    },
    "routing": {
      // "unified" (default) - all servers on one endpoint
      // "perServer" - each server on its own endpoint
      "mode": "unified",
      "basePath": "/mcp"
    },
    "authentication": {
      "enabled": false,
      // Type: "none", "apiKey", "bearer", or "azureAd"
      "type": "none",
      "apiKey": {
        "header": "X-API-Key",
        // Use "env:VAR_NAME" to read from environment variable
        "value": "env:MCP_PROXY_API_KEY"
      },
      // Azure AD / Microsoft Entra ID authentication
      "azureAd": {
        // "instance": "https://login.microsoftonline.com/",
        // "tenantId": "your-tenant-id-or-domain",
        // "clientId": "your-application-client-id",
        // "audience": "api://your-application-client-id",
        // "requiredScopes": ["access_as_user"],
        // "requiredRoles": ["MCP.User"]
      }
    },
    "logging": {
      "logRequests": true,
      "logResponses": false,
      "sensitiveDataMask": true
    },
    // Cross-Origin Resource Sharing (CORS) for HTTP transport.
    // Required when browser-based MCP clients (e.g., MCP Inspector) connect to the proxy.
    // Each backend may override this with its own "cors" block (see "context7" below).
    "cors": {
      "enabled": false,
      // Use ["*"] to allow any origin (incompatible with allowCredentials).
      // Entries support glob '*' wildcards within a single URI segment, e.g.
      //   "http://localhost:*"        -> any localhost port
      //   "https://*.example.com"     -> any single-label subdomain of example.com
      "allowedOrigins": ["http://localhost:6274", "https://*.inspector.example"],
      // Shortcut: allow any http(s)://localhost or 127.0.0.1 on any port.
      // Handy for local browser tools (MCP Inspector) that bind to ephemeral ports.
      "allowAnyLocalhost": false,
      // Omit (or null) to allow any method; the MCP spec uses GET, POST, DELETE, OPTIONS
      "allowedMethods": ["GET", "POST", "DELETE", "OPTIONS"],
      // Omit to allow any header; common ones include Content-Type, Authorization, Mcp-Session-Id
      "allowedHeaders": ["Content-Type", "Authorization", "Mcp-Session-Id"],
      // Mcp-Session-Id is always exposed automatically; list any extras here.
      "exposedHeaders": [],
      "allowCredentials": false,
      "preflightMaxAgeSeconds": 600
    }
  },

  // Backend MCP servers
  "mcp": {
    // Example 1: Local STDIO server (filesystem access)
    "filesystem": {
      "type": "stdio",
      "title": "Filesystem Server",
      "description": "Provides file system access to the workspace",
      "command": "npx",
      "arguments": ["-y", "@anthropic/mcp-server-filesystem", "/workspace"],
      "environment": {
        // Environment variables for the spawned process
        // Use "env:VAR_NAME" to read from current environment
        "NODE_ENV": "production"
      },
      "tools": {
        // Add prefix to all tools: read_file -> fs_read_file
        "prefix": "fs",
        "prefixSeparator": "_",
        "filter": {
          // DenyList dangerous operations
          "mode": "denylist",
          "patterns": ["delete_*", "remove_*", "write_*"],
          "caseInsensitive": true
        }
      },
      "hooks": {
        "preInvoke": [
          {
            "type": "logging",
            "config": {
              "logLevel": "debug",
              "logArguments": true
            }
          }
        ]
      },
      "enabled": true
    },

    // Example 2: Remote SSE server (Context7 documentation)
    "context7": {
      "type": "sse",
      "title": "Context7",
      "description": "Context7 documentation search and retrieval",
      "url": "https://mcp.context7.com/sse",
      "tools": {
        "prefix": "c7"
      },
      // Per-server CORS override. Wins over proxy.cors when in PerServer routing mode.
      // Useful when one server should be reachable from a different set of origins.
      "cors": {
        "enabled": true,
        "allowedOrigins": ["https://docs.example.com"],
        "allowedMethods": ["GET", "POST", "OPTIONS"]
      }
    },

    // Example 3: Azure MCP Server via dnx
    "azure": {
      "type": "stdio",
      "title": "Azure MCP Server",
      "description": "The official Azure MCP Server for Azure resource management",
      "command": "dnx",
      "arguments": ["Azure.Mcp@2.0.0-beta.10", "--yes", "--", "server", "start"],
      "tools": {
        "prefix": "az",
        "filter": {
          // AllowList only specific tools
          "mode": "allowlist",
          "patterns": ["list_*", "get_*", "describe_*"]
        }
      }
    },

    // Example 4: Remote HTTP server with custom headers
    "github": {
      "type": "http",
      "title": "GitHub MCP",
      "description": "GitHub API integration",
      "url": "https://github-mcp.example.com",
      "headers": {
        // Use ${VAR_NAME} syntax for environment variable substitution
        "Authorization": "Bearer ${GITHUB_TOKEN}",
        "X-Custom-Header": "custom-value"
      },
      "tools": {
        "prefix": "gh"
      },
      "hooks": {
        "postInvoke": [
          {
            "type": "outputTransform",
            "config": {
              // Redact sensitive data from output
              "redactPatterns": ["password", "secret", "token", "api_key"]
            }
          }
        ]
      }
    },

    // Example 5: Microsoft Learn MCP (HTTP with auto-detection)
    "microsoft-learn": {
      "type": "http",
      "title": "Microsoft Learn MCP",
      "description": "Microsoft Learn documentation and tutorials",
      "url": "https://learn.microsoft.com/api/mcp"
    },

    // Example 6: Azure-protected backend with client credentials
    "azure-protected-api": {
      "type": "http",
      "title": "Azure Protected API",
      "description": "Backend MCP server protected by Azure AD",
      "url": "https://my-mcp-server.azurewebsites.net/mcp",
      "auth": {
        "type": "AzureAdClientCredentials",
        "azureAd": {
          "tenantId": "contoso.onmicrosoft.com",
          "clientId": "00000000-0000-0000-0000-000000000000",
          "clientSecret": "env:BACKEND_CLIENT_SECRET",
          "scopes": ["api://backend-api/.default"]
        }
      }
    },

    // Example 7: Backend using managed identity (for Azure-hosted deployments)
    "azure-managed-identity": {
      "type": "http",
      "title": "Internal Azure API",
      "url": "https://internal-api.azurewebsites.net/mcp",
      "auth": {
        "type": "AzureAdManagedIdentity",
        "azureAd": {
          "scopes": ["api://internal-api/.default"]
        }
      },
      "enabled": false
    },

    // Example 8: Disabled server (won't be connected)
    "disabled-server": {
      "type": "stdio",
      "command": "node",
      "arguments": ["disabled-server.js"],
      "enabled": false
    }
  }
}
